# Development Environment Template
# Copy this file to .env.local for local development.
# Keep local production plaintext values in .env.production.local.
# Commit only the encrypted .env.production file to git.

# ==========================================
# REQUIRED - Gmail SMTP Configuration
# ==========================================
# Your Gmail email address
GMAIL_USER=your-email@gmail.com
# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-16-character-app-password

# ==========================================
# OPTIONAL - Email Configuration
# ==========================================
# Email address to receive contact form submissions
# If not set, defaults to GMAIL_USER
EMAIL_TO=your-email@gmail.com

# Currently unused by the application.
# Keep these out of .env.local unless you add a real consumer.
# EMAIL_FROM=your-email@gmail.com
# CONTACT_SECRET=your-contact-secret

# ==========================================
# REQUIRED - Site Configuration
# ==========================================
# Base URL of your website (used for metadata, sitemap, robots.txt)
NEXT_PUBLIC_BASE_URL=https://your-domain.com
# Site URL for CORS and security headers
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ==========================================
# REQUIRED - Personal Information
# ==========================================
# Your full name (used in structured data and metadata)
NEXT_PUBLIC_FULL_NAME=Your Full Name
# Your job title/profession
NEXT_PUBLIC_JOB_TITLE=Software Developer
# Your company name
NEXT_PUBLIC_COMPANY=Your Company

# ==========================================
# REQUIRED - Contact Information
# ==========================================
# Your contact email (displayed on the website)
NEXT_PUBLIC_CONTACT_EMAIL=your-email@gmail.com
# Your location (city, country)
NEXT_PUBLIC_CONTACT_LOCATION=Your City, Your Country
# Your phone number (with spaces/formatting)
NEXT_PUBLIC_CONTACT_PHONE=+1 (555) 123-4567
# Your phone number (without spaces, for tel: links)
NEXT_PUBLIC_CONTACT_PHONE_WITHOUT_SPACE=+15551234567

# ==========================================
# REQUIRED - Social Media Links
# ==========================================
# Your GitHub profile URL
NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
# Your LinkedIn profile URL
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourusername

# ==========================================
# OPTIONAL - Social Media
# ==========================================
# Your Twitter handle (without @)
NEXT_PUBLIC_TWITTER_HANDLE=yourusername

# ==========================================
# OPTIONAL - Analytics & Verification
# ==========================================
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Search Console verification meta tag content
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-verification-code

# ==========================================
# OPTIONAL - Security (Future Implementation)
# ==========================================
# reCAPTCHA v2 Site Key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
# Redis URL for rate limiting (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# Redis token for authentication
UPSTASH_REDIS_REST_TOKEN=your-redis-token
